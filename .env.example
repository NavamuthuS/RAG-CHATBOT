# ── .env.example ─────────────────────────────────────────────────────
# Copy this file to .env and fill in your actual values.
#
#   cp .env.example .env
#
# .env is listed in .gitignore so your secret key is never committed.
# ─────────────────────────────────────────────────────────────────────

# Your OpenAI API key — get it from https://platform.openai.com/api-keys
OPENAI_API_KEY=your_api_key_here

# ── Optional overrides (defaults are set in config.py) ────────────────
# Uncomment and change these only if you want to override the defaults.

# DATA_DIR=data/documents
# CHROMA_DB_DIR=chroma_db
# CHUNK_SIZE=1000
# CHUNK_OVERLAP=200
# EMBEDDING_MODEL=text-embedding-3-small
# LLM_MODEL=gpt-4o-mini
# TEMPERATURE=0.3
# TOP_K=4
